{
  "name": "artsee",
  "version": "0.1.0",
  "description": "Artsee - 发现、收藏和分享艺术品的最佳平台",
  "private": true,
  "workspaces": [
    "web"
  ],
  "scripts": {
    "dev:web": "cd web && npm run dev",
    "build:web": "cd web && npm run build",
    "start:web": "cd web && npm run start",
    "lint:web": "cd web && npm run lint",
    "dev:app": "cd app && flutter run",
    "build:app": "cd app && flutter build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:backend": "node tests/backend/supabase-health.mjs",
    "test:web": "npm run test --workspace=web",
    "ensure:dev-user": "node scripts/ensure-dev-test-user.mjs",
    "deploy:web": "bash scripts/deploy-web.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artsee-platform/artsee.git"
  },
  "keywords": [
    "art",
    "gallery",
    "flutter",
    "nextjs",
    "supabase"
  ],
  "author": "Artsee Team",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "axios": "^1.13.6",
    "pg": "^8.20.0"
  }
}
