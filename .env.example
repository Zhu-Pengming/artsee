# 后端探测脚本 tests/backend/supabase-health.mjs 使用（勿提交真实密钥）
# 亦用于 scripts/ensure-dev-test-user.mjs 创建开发者测试账号
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ═══════════════════════════════════════════════════════════════
# 大模型（AI 选校 /api/v1/ai/schools/search）
# 实际生效位置：web/.env.local（开发）或托管平台环境变量（生产）
# ═══════════════════════════════════════════════════════════════
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
MOONSHOT_API_KEY=
AI_MODEL=gpt-4o-mini
