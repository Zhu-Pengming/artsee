# Next.js 开发（复制为 web/.env.local）
NODE_ENV=development

# Supabase（与 Flutter 共用同一项目）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 大模型（AI 选校 /api/v1/ai/schools/search；与 /api/chat 可共用）
# OpenAI 兼容：也可填 Moonshot、DeepSeek 等 base URL
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# 若使用 Kimi：OPENAI_BASE_URL=https://api.moonshot.cn/v1 且密钥填 MOONSHOT 或复用 OPENAI_API_KEY
MOONSHOT_API_KEY=
AI_MODEL=gpt-4o-mini

# 可选：仅文档/运维用
# NEXT_PUBLIC_APP_URL=http://localhost:3333
