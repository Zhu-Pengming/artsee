# Next.js 开发（复制为 web/.env.local）
NODE_ENV=development

# Supabase（与 Flutter 共用同一项目）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 大模型（AI 选校 /api/v1/ai/schools/search；与 /api/chat 可共用）
# OpenAI 兼容：也可填 Moonshot、DeepSeek 等 base URL
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# 若使用 Kimi：OPENAI_BASE_URL=https://api.moonshot.cn/v1 且密钥填 MOONSHOT 或复用 OPENAI_API_KEY
MOONSHOT_API_KEY=
AI_MODEL=gpt-4o-mini
# AI_BASE_URL 为 OPENAI_BASE_URL 的 fallback，通常无需单独配置
# AI_BASE_URL=

# ============================================
# Embedding 配置（选择一种方式）
# ============================================

# 方式 1: 智谱 GLM（在线，1024 维）
# EMBEDDING_PROVIDER=glm
# GLM_API_KEY=
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# EMBEDDING_MODEL=embedding-2
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_BATCH_SIZE=50

# 方式 2: 本地 Xinference（推荐：bge-small-zh-v1.5，512 维）
EMBEDDING_PROVIDER=xinference
XINFERENCE_BASE_URL=http://localhost:9997/v1
XINFERENCE_API_KEY=dummy
EMBEDDING_MODEL=bge-small-zh-v1.5
EMBEDDING_DIMENSIONS=512
EMBEDDING_BATCH_SIZE=32

# 方式 3: 本地 Ollama（512 维）
# EMBEDDING_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_API_KEY=dummy
# EMBEDDING_MODEL=bge-small-zh-v1.5
# EMBEDDING_DIMENSIONS=512
# EMBEDDING_BATCH_SIZE=32

# 方式 4: OpenAI（在线，1536 维）
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
# EMBEDDING_BATCH_SIZE=100

# ============================================
# Phase 1: 统一 Pipeline 灰度开关
# ============================================
# 默认为 true（使用统一 pipeline + RAG）
# 设为 false 则回退到旧的硬编码 prompt + Moonshot
USE_UNIFIED_CONSULT=true

# 可选：仅文档/运维用
# NEXT_PUBLIC_APP_URL=http://localhost:9090
