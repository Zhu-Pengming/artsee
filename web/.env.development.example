# Next.js 开发（复制为 web/.env.local）
NODE_ENV=development

# Supabase（与 Flutter 共用同一项目）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 大模型（/api/v1/ai/consult、/api/v1/ai/chat、/api/v1/ai/schools/search 共用）
# DeepSeek / OpenAI 兼容配置。使用 DeepSeek 时推荐填下面三项。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI 兼容 fallback：也可填 Moonshot、DeepSeek 等 base URL
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# 若使用 Kimi：OPENAI_BASE_URL=https://api.moonshot.cn/v1 且密钥填 MOONSHOT 或复用 OPENAI_API_KEY
MOONSHOT_API_KEY=
AI_MODEL=gpt-4o-mini
# AI_BASE_URL 为 OPENAI_BASE_URL 的 fallback，通常无需单独配置
# AI_BASE_URL=

# ============================================
# Embedding 配置（选择一种方式）
# ============================================

# 方式 1: 智谱 GLM（在线，1024 维）
# EMBEDDING_PROVIDER=glm
# GLM_API_KEY=
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# EMBEDDING_MODEL=embedding-2
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_BATCH_SIZE=50

# 方式 2: 本地 Ollama bge-m3（推荐：本项目默认，1024 维）
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=dummy
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=50

# 方式 3: 本地 Xinference
# EMBEDDING_PROVIDER=xinference
# XINFERENCE_BASE_URL=http://localhost:9997/v1
# XINFERENCE_API_KEY=dummy
# EMBEDDING_MODEL=bge-m3
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_BATCH_SIZE=32

# 方式 4: OpenAI（在线，1536 维）
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
# EMBEDDING_BATCH_SIZE=100

# ============================================
# Phase 1: 统一 Pipeline 灰度开关
# ============================================
# 默认为 true（使用统一 pipeline + RAG）
# 设为 false 则回退到旧的硬编码 prompt + Moonshot
USE_UNIFIED_CONSULT=true

# 可选：仅文档/运维用
# NEXT_PUBLIC_APP_URL=http://localhost:9090

# ============================================
# 腾讯云：COS 上传 + 内容安全审核
# ============================================
# 服务端专用，勿暴露给 Flutter / 浏览器。
TENCENT_CLOUD_SECRET_ID=
TENCENT_CLOUD_SECRET_KEY=
TENCENT_CLOUD_REGION=ap-guangzhou
# 如果使用临时密钥，可同时提供 token。
# TENCENT_CLOUD_SECURITY_TOKEN=

# COS Bucket 需要包含 appid，例如 artsee-1250000000。
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=ap-guangzhou
# 可选：CDN/自定义域名，例如 https://assets.artiqore.com
# TENCENT_COS_PUBLIC_BASE_URL=
TENCENT_COS_SIGN_EXPIRES_SECONDS=900

# 内容安全默认使用 tms/ims 的 2020-12-29 API，可按业务策略覆盖 BizType。
# TENCENT_CONTENT_SAFETY_TEXT_BIZ_TYPE=
# TENCENT_CONTENT_SAFETY_IMAGE_BIZ_TYPE=
