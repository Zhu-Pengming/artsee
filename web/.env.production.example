# 生产构建与部署（在托管平台配置为环境变量，勿提交真实密钥）
NODE_ENV=production

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 大模型（/api/v1/ai/consult、/api/v1/ai/chat、/api/v1/ai/schools/search 共用）
# DeepSeek / OpenAI 兼容配置。使用 DeepSeek 时推荐填下面三项。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI 兼容 fallback
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
MOONSHOT_API_KEY=
AI_MODEL=gpt-4o-mini
# AI_BASE_URL 为 OPENAI_BASE_URL 的 fallback，通常无需单独配置
# AI_BASE_URL=

# Embedding 配置（本项目默认：本地 Ollama bge-m3，1024 维）
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=dummy
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=50

# 如果使用本地 Xinference（需自行部署）:
# EMBEDDING_PROVIDER=xinference
# XINFERENCE_BASE_URL=http://your-xinference-server:9997/v1
# XINFERENCE_API_KEY=dummy
# EMBEDDING_MODEL=bge-m3
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_BATCH_SIZE=32

# 部署后的站点 URL（若前端或回调需要）
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# 腾讯云：COS 上传 + 内容安全审核（服务端专用）
TENCENT_CLOUD_SECRET_ID=
TENCENT_CLOUD_SECRET_KEY=
TENCENT_CLOUD_REGION=ap-guangzhou
# TENCENT_CLOUD_SECURITY_TOKEN=

TENCENT_COS_BUCKET=
TENCENT_COS_REGION=ap-guangzhou
# TENCENT_COS_PUBLIC_BASE_URL=https://assets.artiqore.com
TENCENT_COS_SIGN_EXPIRES_SECONDS=900

# TENCENT_CONTENT_SAFETY_TEXT_BIZ_TYPE=
# TENCENT_CONTENT_SAFETY_IMAGE_BIZ_TYPE=

# 腾讯云：即时通信 IM / Chat（服务端专用，勿暴露给 Flutter / 浏览器）
TENCENT_IM_SDK_APP_ID=
TENCENT_IM_SECRET_KEY=
TENCENT_IM_ADMIN_USER_ID=administrator
TENCENT_IM_USER_SIG_EXPIRES_SECONDS=604800
# 国内站默认 console.tim.qq.com；若腾讯云提示 SDKAppID 与域名不匹配，再按应用地域改这里。
TENCENT_IM_REST_HOST=console.tim.qq.com
# 若只想先生成 UserSig、不调用 IM account_import，可设为 1。
TENCENT_IM_SKIP_ACCOUNT_IMPORT=0
# 若只想本地测试 Supabase 好友关系、不调用 IM friend_add，可设为 1。
TENCENT_IM_SKIP_FRIENDSHIP_SYNC=0
